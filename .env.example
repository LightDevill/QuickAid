# Environment
NODE_ENV=development
PORT=8080

# Database
DATABASE_URL=postgres://quickaid:quickaid_secret@localhost:5432/quickaid
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ALGORITHM=HS256

# Service Ports
AUTH_SERVICE_PORT=3001
CORE_SERVICE_PORT=3002
WORKFLOW_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
ANALYTICS_SERVICE_PORT=3005

# External APIs
SMS_API_KEY=your-sms-api-key
SMS_API_URL=https://api.sms-provider.com/v1

# Security
ALERT_SECRET=QUICKAID_TEST_SECRET
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100  
OTP_RATE_LIMIT=5

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_WEBSOCKETS=true
