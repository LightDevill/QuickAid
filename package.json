{
  "name": "quickaid",
  "version": "1.0.0",
  "description": "Production-ready healthcare emergency response system",
  "main": "src/index.js",
  "scripts": {
    "dev": "node src/index.js",
    "dev:services": "concurrently \"npm run dev:auth\" \"npm run dev:core\" \"npm run dev:workflow\" \"npm run dev:notify\" \"npm run dev:analytics\"",
    "dev:auth": "node backend/services/auth-service/src/server.js",
    "dev:core": "node backend/services/core-service/src/server.js",
    "dev:workflow": "node backend/services/workflow-service/src/server.js",
    "dev:notify": "node backend/services/notification-service/src/server.js",
    "dev:analytics": "node backend/services/analytics-service/src/server.js",
    "start": "node src/index.js",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:coverage": "jest --coverage",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:prod": "NODE_ENV=production node scripts/migrate.js",
    "db:seed": "node data/seed.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "healthcare",
    "emergency",
    "hospital",
    "booking",
    "realtime"
  ],
  "author": "QUICKAID Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
